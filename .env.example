# Backend API base URL.
# In production this is empty (Nginx proxies /api/* to the backend container).
# In local development, point to the running backend service.
VITE_API_URL=http://localhost:8080

# Application-level Bearer token (matches APP_API_KEY on the backend).
# Required when APP_AUTH_ENABLED=true on the backend.
# Obtain the value from the project's secret manager or from the operator.
# Leave empty to disable auth injection (only safe behind Cloud Run IAP).
VITE_API_KEY=
